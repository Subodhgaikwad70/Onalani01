# Copy to `.env` or `.env.local` and replace placeholders.
#
# Optional dev fixtures (needs SUPABASE_SERVICE_ROLE_KEY): npm run seed:dev
# Photo uploads (admin property/listing forms): npm run storage:setup
# Demo users: guest@example.com, admin@example.com, superadmin@example.com — password TestPass12345!
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Preferred key name in this codebase (publishable / anon):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me
# Legacy alias also accepted:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me

# Server-only: never expose to the browser (Dashboard → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me-service-role

# --- Stripe (Dashboard → Developers → API keys) ---
# Use the matching secret + publishable pair from the same account (both pk_test_… and sk_test_…).
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# --- App URLs ---
# Used in outbound emails (message notifications); include scheme, no trailing slash.
APP_BASE_URL=http://localhost:3000

# --- Email (Resend) — optional until you send mail ---
# RESEND_API_KEY=re_replace_me
# NOTIFICATION_FROM_EMAIL=Onalani <noreply@yourdomain.com>

# --- Cron (protect /api/cron/* when deployed) ---
# CRON_SECRET=long-random-string

# --- Beds24 integration — optional ---
# BEDS24_API_TOKEN=          # Short-lived access token (used until expiry)
# BEDS24_REFRESH_TOKEN=      # Long-lived; mints a new access token when API token expires
# BEDS24_WEBHOOK_SECRET=
# BEDS24_API_BASE=https://beds24.com/api/v2
# Set to false until Stripe is connected in Beds24 (Channels → Stripe).
# BEDS24_STRIPE_ENABLED=false
# Beds24 Connect publishable key (defaults to Beds24 wiki value if unset):
# BEDS24_STRIPE_PUBLISHABLE_KEY=pk_live_zWSW2ykzZoq4mYcKg9c8jmHS
# Set to 1/true on serverless if you use GET /api/cron/cache-warm instead of in-process refresh:
# BEDS24_DISABLE_BACKGROUND_REFRESH=
